---
import config from "../../astro-i18next.config";

const routeTranslations = config.routes?.en || {};
const routeMappingJson = JSON.stringify(routeTranslations);

const currentPath = Astro.url.pathname;
const isEn = /^\/en(\/|$)/.test(currentPath);
const currentLang = isEn ? "en" : "es";

const enToEs: Record<string, string> = Object.fromEntries(
  Object.entries(routeTranslations).map(([es, en]) => [en, es]),
);
const stripped = isEn ? currentPath.replace(/^\/en(?=\/|$)/, "") : currentPath;
const segments = stripped.split("/").filter(Boolean);
const esSegments = isEn ? segments.map((seg) => enToEs[seg] || seg) : segments;
const enSegments = isEn ? segments : segments.map((seg) => routeTranslations[seg] || seg);
const esPath = "/" + esSegments.join("/");
const enPath = "/en" + (enSegments.length ? "/" + enSegments.join("/") : "");
---

<div class="flex items-center gap-3 editorial-meta" data-lang-picker data-route-map={routeMappingJson}>
  <a
    href={esPath}
    data-lang-es
    class={currentLang === 'es' ? 'text-paper' : 'text-paper-dim hover:text-paper transition-colors'}
    aria-current={currentLang === 'es' ? 'true' : undefined}
  >
    ES
  </a>
  <span class="text-paper-dim" aria-hidden="true">/</span>
  <a
    href={enPath}
    data-lang-en
    class={currentLang === 'en' ? 'text-paper' : 'text-paper-dim hover:text-paper transition-colors'}
    aria-current={currentLang === 'en' ? 'true' : undefined}
  >
    EN
  </a>
</div>

<script>
  function syncLanguagePickers() {
    document.querySelectorAll<HTMLElement>("[data-lang-picker]").forEach((picker) => {
      const raw = picker.dataset.routeMap;
      if (!raw) return;
      const esToEn = JSON.parse(raw) as Record<string, string>;
      const enToEs: Record<string, string> = Object.fromEntries(
        Object.entries(esToEn).map(([es, en]) => [en, es]),
      );

      const path = window.location.pathname;
      const isEn = /^\/en(\/|$)/.test(path);
      const stripped = isEn ? path.replace(/^\/en(?=\/|$)/, "") : path;
      const segments = stripped.split("/").filter(Boolean);

      const esSegs = isEn ? segments.map((s) => enToEs[s] || s) : segments;
      const enSegs = isEn ? segments : segments.map((s) => esToEn[s] || s);

      const esPath = "/" + esSegs.join("/");
      const enPath = "/en" + (enSegs.length ? "/" + enSegs.join("/") : "");

      const esLink = picker.querySelector<HTMLAnchorElement>("[data-lang-es]");
      const enLink = picker.querySelector<HTMLAnchorElement>("[data-lang-en]");

      if (esLink) {
        esLink.href = esPath;
        if (isEn) {
          esLink.className = "text-paper-dim hover:text-paper transition-colors";
          esLink.removeAttribute("aria-current");
        } else {
          esLink.className = "text-paper";
          esLink.setAttribute("aria-current", "true");
        }
      }
      if (enLink) {
        enLink.href = enPath;
        if (isEn) {
          enLink.className = "text-paper";
          enLink.setAttribute("aria-current", "true");
        } else {
          enLink.className = "text-paper-dim hover:text-paper transition-colors";
          enLink.removeAttribute("aria-current");
        }
      }
    });
  }

  document.addEventListener("astro:after-swap", syncLanguagePickers);
</script>

---
import LanguagePicker from "./LanguagePicker.astro";
import { localizePath } from "astro-i18next";
import { t } from "i18next";
---

<header class="sticky top-0 z-50 bg-ink/80 backdrop-blur-md border-b hairline" transition:persist="site-header">
  <nav class="max-w-[1600px] mx-auto px-6 lg:px-12">
    <div class="flex justify-between items-center h-20">
      <a
        href={localizePath("/")}
        class="font-mono text-sm tracking-tight text-paper hover:text-paper-muted transition-colors lowercase"
      >
        jfrankrobles<span class="text-paper-dim">.</span>
      </a>

      <div class="hidden md:flex md:items-center md:gap-10">
        <a
          href={localizePath("/")}
          class="editorial-meta hover:text-paper transition-colors"
        >
          {t("nav.home")}
        </a>
        <a
          href={localizePath("/ingenieria")}
          class="editorial-meta hover:text-paper transition-colors"
        >
          {t("nav.engineering")}
        </a>
        <a
          href={localizePath("/negocios")}
          class="editorial-meta hover:text-paper transition-colors"
        >
          {t("nav.business")}
        </a>
        <a
          href={localizePath("/proyectos")}
          class="editorial-meta hover:text-paper transition-colors"
        >
          {t("nav.projects")}
        </a>
        <LanguagePicker />
        <button
          type="button"
          data-theme-toggle
          class="editorial-meta text-paper-dim hover:text-paper transition-colors theme-toggle"
          aria-label="Toggle theme"
        >
          <span data-theme-label-dark>DARK</span>
          <span data-theme-label-light>LIGHT</span>
        </button>
        <a
          href={localizePath("/contacto")}
          class="editorial-meta border-b border-paper text-paper hover:text-paper-muted hover:border-paper-muted pb-1 transition-colors"
        >
          {t("nav.contact")} →
        </a>
      </div>

      <div class="md:hidden">
        <button
          id="mobile-menu-button"
          type="button"
          class="text-paper hover:text-paper-muted p-2"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <div
      id="mobile-menu"
      class="hidden md:hidden pb-6 border-t hairline"
    >
      <div class="flex flex-col gap-1 pt-4">
        <a
          href={localizePath("/")}
          class="editorial-meta py-3 hover:text-paper transition-colors"
        >
          {t("nav.home")}
        </a>
        <a
          href={localizePath("/ingenieria")}
          class="editorial-meta py-3 hover:text-paper transition-colors"
        >
          {t("nav.engineering")}
        </a>
        <a
          href={localizePath("/negocios")}
          class="editorial-meta py-3 hover:text-paper transition-colors"
        >
          {t("nav.business")}
        </a>
        <a
          href={localizePath("/proyectos")}
          class="editorial-meta py-3 hover:text-paper transition-colors"
        >
          {t("nav.projects")}
        </a>
        <div class="py-3 flex items-center gap-6">
          <LanguagePicker />
          <button
            type="button"
            data-theme-toggle
            class="editorial-meta text-paper-dim hover:text-paper transition-colors theme-toggle"
            aria-label="Toggle theme"
          >
            <span data-theme-label-dark>DARK</span>
            <span data-theme-label-light>LIGHT</span>
          </button>
        </div>
        <a
          href={localizePath("/contacto")}
          class="editorial-meta py-3 text-paper hover:text-paper-muted transition-colors"
        >
          {t("nav.contact")} →
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  .theme-toggle [data-theme-label-dark],
  .theme-toggle [data-theme-label-light] {
    display: none;
  }
  :root[data-theme="dark"] .theme-toggle [data-theme-label-dark],
  :root[data-theme="light"] .theme-toggle [data-theme-label-light] {
    display: inline;
  }
</style>

<script>
  const menuButton = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  menuButton?.addEventListener("click", () => {
    const expanded = menuButton.getAttribute("aria-expanded") === "true";
    menuButton.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("hidden");
  });

  document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const current = document.documentElement.getAttribute("data-theme") ?? "dark";
      const next = current === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      try {
        localStorage.setItem("theme", next);
      } catch (e) {
        /* ignore */
      }
    });
  });
</script>

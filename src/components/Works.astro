---
import { t } from "i18next";

const timeline = [
  {
    company: t("work.company"),
    title: t("work.position"),
    date: t("work.date"),
    location: t("work.location"),
    description: t("work.description"),
    achievements: [
      {
        title: t("work.project1Title"),
        description: t("work.project1Desc"),
        tech: ["Next.js", "PayloadCMS", "Meilisearch", "Tailwind CSS", "Vercel"]
      },
      {
        title: t("work.project2Title"),
        description: t("work.project2Desc"),
        tech: ["Next.js", "Supabase", "PostgreSQL", "Meilisearch"]
      },
      {
        title: t("work.project3Title"),
        description: t("work.project3Desc"),
        tech: ["Meilisearch", "Elasticsearch", "React"]
      }
    ],
    skills: [
      t("work.skill1"),
      t("work.skill2"),
      t("work.skill3"),
      t("work.skill4"),
      t("work.skill5"),
      t("work.skill6")
    ]
  },
];
---

<section class="w-full">
  <p class="editorial-meta mb-8">Experiencia</p>
  <h2 class="editorial-display text-3xl md:text-5xl text-paper mb-16">
    {t("work.title")}
  </h2>

  {timeline.map((item) => (
    <article class="border-t hairline pt-12">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <div class="md:col-span-4">
          <p class="editorial-meta text-paper-dim mb-3">{item.date}</p>
          <h3 class="editorial-display text-2xl md:text-3xl text-paper mb-2">
            {item.company}
          </h3>
          <p class="text-paper-muted text-sm mb-1">{item.title}</p>
          <p class="text-paper-dim text-sm">{item.location}</p>
        </div>

        <div class="md:col-span-7 md:col-start-6">
          <p class="text-paper-muted text-lg leading-relaxed text-pretty">
            {item.description}
          </p>
        </div>
      </div>

      <div class="border-t hairline pt-12 mb-16">
        <p class="editorial-meta mb-10">{t("work.featuredProjects")}</p>
        <div class="space-y-12">
          {item.achievements.map((achievement, i) => (
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
              <p class="editorial-meta md:col-span-1 text-paper-dim">
                0{i + 1}
              </p>
              <div class="md:col-span-11">
                <h4 class="editorial-display text-xl md:text-2xl text-paper mb-4">
                  {achievement.title}
                </h4>
                <p class="text-paper-muted leading-relaxed mb-6 text-pretty max-w-3xl">
                  {achievement.description}
                </p>
                <div class="flex flex-wrap gap-x-4 gap-y-2">
                  {achievement.tech.map((tech) => (
                    <span class="font-mono text-xs text-paper-muted">{tech}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="border-t hairline pt-12">
        <p class="editorial-meta mb-8">{t("work.skillsDeveloped")}</p>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-3 max-w-4xl">
          {item.skills.map((skill, i) => (
            <li class="flex gap-4 text-paper-muted">
              <span class="font-mono text-xs text-paper-dim pt-1 select-none" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span>{skill}</span>
            </li>
          ))}
        </ul>
      </div>
    </article>
  ))}
</section>

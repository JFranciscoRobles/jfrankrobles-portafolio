---
import { SOCIAL_LINKS, SITE_AUTHOR } from "../consts";
import { localizePath } from "astro-i18next";
import { t } from "i18next";

const year = new Date().getFullYear();
---

<footer class="bg-ink border-t hairline mt-32" transition:persist="site-footer">
  <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8">
      <div class="md:col-span-5">
        <p class="editorial-meta mb-4">{t("footer.contact")}</p>
        <a
          href={`mailto:${SOCIAL_LINKS.email}`}
          class="editorial-display text-2xl md:text-4xl text-paper hover:text-paper-muted transition-colors break-all"
        >
          {SOCIAL_LINKS.email}
          <span class="text-paper-dim"> →</span>
        </a>
      </div>

      <div class="md:col-span-3 md:col-start-7">
        <p class="editorial-meta mb-4">{t("footer.navigation")}</p>
        <ul class="space-y-2">
          <li>
            <a href={localizePath("/")} class="text-paper hover:text-paper-muted transition-colors">
              {t("nav.home")}
            </a>
          </li>
          <li>
            <a href={localizePath("/ingenieria")} class="text-paper hover:text-paper-muted transition-colors">
              {t("nav.engineering")}
            </a>
          </li>
          <li>
            <a href={localizePath("/negocios")} class="text-paper hover:text-paper-muted transition-colors">
              {t("nav.business")}
            </a>
          </li>
          <li>
            <a href={localizePath("/proyectos")} class="text-paper hover:text-paper-muted transition-colors">
              {t("nav.projects")}
            </a>
          </li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <p class="editorial-meta mb-4">Social</p>
        <ul class="space-y-2">
          <li>
            <a
              href={SOCIAL_LINKS.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="text-paper hover:text-paper-muted transition-colors"
            >
              LinkedIn ↗
            </a>
          </li>
          <li>
            <a
              href={SOCIAL_LINKS.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-paper hover:text-paper-muted transition-colors"
            >
              GitHub ↗
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t hairline mt-16 pt-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <p class="editorial-meta">
        © {year} — {SITE_AUTHOR}
      </p>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        <a
          href={localizePath("/sitemap")}
          class="editorial-meta text-paper-dim hover:text-paper transition-colors"
        >
          Sitemap
        </a>
        <p class="editorial-meta">
          {t("footer.madeWith")} Astro + Tailwind
        </p>
      </div>
    </div>
  </div>
</footer>

---
import { t } from "i18next";
import { localizePath } from "astro-i18next";
import { SOCIAL_LINKS } from "../consts";

const year = new Date().getFullYear();
---

<!-- Hero -->
<section class="border-b hairline">
  <div class="max-w-[1600px] mx-auto px-6 lg:px-12 pt-24 pb-32 md:pt-40 md:pb-48">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8 items-end">
      <div class="md:col-span-8">
        <p class="editorial-meta mb-12">
          {t("home.badge")} <span class="text-paper-dim">— {year}</span>
        </p>

        <h1 class="editorial-display text-[2.5rem] sm:text-[3.5rem] md:text-[5rem] lg:text-[6rem] text-paper text-balance">
          {t("home.greeting")}
          <br />
          <span class="text-paper-muted">{t("home.name")}.</span>
        </h1>
      </div>

      <div class="md:col-span-4 md:col-start-9">
        <div class="border-l hairline pl-6">
          <p class="text-paper-muted text-base leading-relaxed mb-4 text-pretty" set:html={t("home.description1")} />
          <p class="text-paper-dim text-sm leading-relaxed text-pretty" set:html={t("home.description2")} />
        </div>
      </div>
    </div>

    <div class="mt-20 md:mt-32 flex flex-wrap items-center gap-x-10 gap-y-4">
      <a
        href={localizePath("/ingenieria")}
        class="editorial-meta text-paper border-b border-paper hover:border-paper-muted hover:text-paper-muted pb-1 transition-colors"
      >
        {t("home.viewEngineering")} →
      </a>
      <a
        href={localizePath("/negocios")}
        class="editorial-meta text-paper-muted hover:text-paper transition-colors"
      >
        {t("home.viewBusiness")} →
      </a>
      <a
        href={localizePath("/proyectos")}
        class="editorial-meta text-paper-muted hover:text-paper transition-colors"
      >
        {t("nav.projects")} →
      </a>
    </div>
  </div>
</section>

<!-- Portrait + presentación -->
<section class="border-b hairline bg-ink-raised">
  <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-24 md:py-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-center">
      <div class="md:col-span-5">
        <div class="aspect-[3/4] bg-ink overflow-hidden">
          <img
            src="/yo.jpg"
            alt="J. Francisco Robles"
            width="600"
            height="800"
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <div class="md:col-span-6 md:col-start-7">
        <p class="editorial-meta mb-8">Portrait — 01</p>
        <h2 class="editorial-display text-3xl md:text-5xl text-paper mb-8 text-balance">
          {t("home.whoIHelp")}
        </h2>
        <p class="text-paper-muted text-lg leading-relaxed text-pretty">
          {t("home.forBusinessDesc")}
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Dos audiencias -->
<section>
  <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-24 md:py-32">
    <p class="editorial-meta mb-16">Servicios — 02</p>

    <div class="grid grid-cols-1 md:grid-cols-2">
      <a
        href={localizePath("/ingenieria")}
        class="group block py-12 md:py-20 md:pr-12 border-b md:border-b-0 md:border-r hairline"
      >
        <p class="editorial-meta mb-6 text-paper-dim">01 / Tech</p>
        <h3 class="editorial-display text-2xl md:text-4xl text-paper mb-6 group-hover:text-paper-muted transition-colors duration-300">
          {t("home.forRecruiters")}
        </h3>
        <p class="text-paper-muted leading-relaxed mb-8 text-pretty">
          {t("home.forRecruitersDesc")}
        </p>
        <span class="editorial-meta text-paper inline-flex items-center gap-2 border-b border-paper pb-1 group-hover:border-paper-muted group-hover:text-paper-muted transition-colors">
          {t("home.viewProfile")}
          <span aria-hidden="true">→</span>
        </span>
      </a>

      <a
        href={localizePath("/negocios")}
        class="group block py-12 md:py-20 md:pl-12"
      >
        <p class="editorial-meta mb-6 text-paper-dim">02 / Business</p>
        <h3 class="editorial-display text-2xl md:text-4xl text-paper mb-6 group-hover:text-paper-muted transition-colors duration-300">
          {t("home.forBusiness")}
        </h3>
        <p class="text-paper-muted leading-relaxed mb-8 text-pretty">
          {t("home.forBusinessDesc")}
        </p>
        <span class="editorial-meta text-paper inline-flex items-center gap-2 border-b border-paper pb-1 group-hover:border-paper-muted group-hover:text-paper-muted transition-colors">
          {t("home.viewServices")}
          <span aria-hidden="true">→</span>
        </span>
      </a>
    </div>
  </div>
</section>

<!-- Contact strip -->
<section class="border-t hairline bg-ink-raised">
  <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-24 md:py-32">
    <p class="editorial-meta mb-8">Contacto — 03</p>
    <a
      href={`mailto:${SOCIAL_LINKS.email}`}
      class="editorial-display text-3xl md:text-5xl lg:text-6xl text-paper hover:text-paper-muted transition-colors inline-block break-all"
    >
      {SOCIAL_LINKS.email}
      <span class="text-paper-dim"> →</span>
    </a>

    <div class="mt-16 flex flex-wrap gap-x-8 gap-y-3">
      <a
        href={SOCIAL_LINKS.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="editorial-meta text-paper-muted hover:text-paper transition-colors"
      >
        LinkedIn ↗
      </a>
      <a
        href={SOCIAL_LINKS.github}
        target="_blank"
        rel="noopener noreferrer"
        class="editorial-meta text-paper-muted hover:text-paper transition-colors"
      >
        GitHub ↗
      </a>
    </div>
  </div>
</section>

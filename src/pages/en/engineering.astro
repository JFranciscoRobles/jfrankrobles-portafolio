---
import Global from "../../layouts/Global.astro";
import { SOCIAL_LINKS } from "../../consts";
import { localizePath } from "astro-i18next";
import { t, changeLanguage } from "i18next";
import { HeadHrefLangs } from "astro-i18next/components";

changeLanguage("en");
---

<Global
  pageTitle="Software Architect - J. Francisco Robles"
  description="Technical profile of J. Francisco Robles, Software Architect with over 4 years of experience in complex enterprise systems, scalable APIs and modern architecture."
  locale="en"
>
  <HeadHrefLangs slot="head" />

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 pt-24 pb-20 md:pt-32 md:pb-24">
      <p class="editorial-meta mb-12">Engineering — 01</p>
      <h1 class="editorial-display text-[2.25rem] sm:text-[3rem] md:text-[5rem] text-paper text-balance mb-12">
        {t("engineering.title")}
      </h1>
      <p class="text-paper-muted text-lg md:text-xl max-w-3xl leading-relaxed text-pretty mb-12">
        {t("engineering.subtitle")}
      </p>
      <div class="flex flex-wrap gap-x-10 gap-y-4">
        <a
          href="/cv.pdf"
          download
          class="editorial-meta text-paper border-b border-paper hover:border-paper-muted hover:text-paper-muted pb-1 transition-colors"
        >
          {t("engineering.downloadCV")} ↓
        </a>
        <a
          href={SOCIAL_LINKS.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="editorial-meta text-paper-muted hover:text-paper transition-colors"
        >
          {t("engineering.contactLinkedIn")} ↗
        </a>
      </div>
    </div>
  </section>

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-12">
        <p class="md:col-span-2 editorial-meta">02 / Profile</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("engineering.profile")}
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
        <div class="md:col-span-2"></div>
        <p class="md:col-span-9 text-paper-muted text-lg leading-relaxed text-pretty mb-12 max-w-3xl">
          {t("engineering.profileDesc")}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
        <p class="md:col-span-2 editorial-meta text-paper-dim">{t("engineering.expertIn")}</p>
        <ul class="md:col-span-9 space-y-4">
          {['expertise1','expertise2','expertise3','expertise4','expertise5','expertise6'].map((key, i) => (
            <li class="flex gap-6 text-paper-muted leading-relaxed border-t hairline pt-4">
              <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="text-paper">{t(`engineering.${key}`)}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="border-b hairline bg-ink-raised">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <p class="md:col-span-2 editorial-meta">03 / Experience</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("engineering.experience")}
        </h2>
      </div>

      <article class="border-t hairline pt-12">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
          <div class="md:col-span-4">
            <p class="editorial-meta text-paper-dim mb-3">{t("engineering.date")}</p>
            <h3 class="editorial-display text-2xl md:text-3xl text-paper mb-2">{t("engineering.company")}</h3>
            <p class="text-paper-muted text-sm mb-1">{t("engineering.position")}</p>
            <p class="text-paper-dim text-sm">{t("engineering.location")}</p>
          </div>
          <p class="md:col-span-7 md:col-start-6 text-paper-muted text-lg leading-relaxed text-pretty">
            {t("engineering.companyDesc")}
          </p>
        </div>

        <div class="border-t hairline pt-12 mb-16">
          <p class="editorial-meta mb-10">{t("engineering.featuredProjects")}</p>
          <div class="space-y-12">
            {[1, 2, 3].map((n) => (
              <a
                href={localizePath(`/proyectos/${t(`engineering.project${n}Slug`)}`)}
                class="group grid grid-cols-1 md:grid-cols-12 gap-8 border-t hairline pt-8"
              >
                <p class="editorial-meta md:col-span-1 text-paper-dim">0{n}</p>
                <div class="md:col-span-11">
                  <h4 class="editorial-display text-xl md:text-2xl text-paper mb-4 group-hover:text-paper-muted transition-colors">
                    {t(`engineering.project${n}Title`)}
                    <span class="text-paper-dim"> →</span>
                  </h4>
                  <p class="text-paper-muted leading-relaxed mb-4 text-pretty max-w-3xl">{t(`engineering.project${n}Desc`)}</p>
                  <p class="font-mono text-xs text-paper-dim mb-1">{t(`engineering.project${n}Stack`)}</p>
                  <p class="font-mono text-xs text-paper-muted mb-4">{t(`engineering.project${n}Result`)}</p>
                  <span class="editorial-meta text-paper border-b border-paper group-hover:border-paper-muted group-hover:text-paper-muted pb-1 transition-colors inline-block">
                    {t("engineering.viewCaseStudy")} →
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="border-t hairline pt-12">
          <p class="editorial-meta mb-8">{t("engineering.skillsDeveloped")}</p>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-3 max-w-4xl">
            {['skill1','skill2','skill3','skill4','skill5','skill6'].map((key, i) => (
              <li class="flex gap-4 text-paper-muted">
                <span class="font-mono text-xs text-paper-dim pt-1 select-none" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span>{t(`engineering.${key}`)}</span>
              </li>
            ))}
          </ul>
        </div>
      </article>
    </div>
  </section>

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <p class="md:col-span-2 editorial-meta">04 / Stack</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("engineering.techStack")}
        </h2>
      </div>

      <dl class="space-y-12">
        {[
          { key: 'stackDaily', descKey: 'stackDailyDesc', techKey: 'stackDailyTech', n: '01' },
          { key: 'stackFrequent', descKey: 'stackFrequentDesc', techKey: 'stackFrequentTech', n: '02' },
          { key: 'stackKnown', descKey: 'stackKnownDesc', techKey: 'stackKnownTech', n: '03' },
        ].map((item) => (
          <div class="grid grid-cols-1 md:grid-cols-12 gap-8 border-t hairline pt-8">
            <div class="md:col-span-4">
              <p class="editorial-meta text-paper-dim mb-3">{item.n}</p>
              <dt class="editorial-display text-2xl md:text-3xl text-paper mb-3">{t(`engineering.${item.key}`)}</dt>
              <p class="text-paper-muted text-sm leading-relaxed text-pretty">{t(`engineering.${item.descKey}`)}</p>
            </div>
            <dd class="md:col-span-7 md:col-start-6 font-mono text-sm md:text-base text-paper leading-relaxed">{t(`engineering.${item.techKey}`)}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="border-b hairline bg-ink-raised">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <p class="md:col-span-2 editorial-meta">05 / Achievements</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("engineering.achievements")}
        </h2>
      </div>
      <ul class="space-y-4 max-w-4xl">
        {['achievement1','achievement2','achievement3','achievement4','achievement5','achievement6'].map((key, i) => (
          <li class="flex gap-6 text-paper-muted leading-relaxed border-t hairline pt-6">
            <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-paper text-lg">{t(`engineering.${key}`)}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <p class="md:col-span-2 editorial-meta">06 / Approach</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("engineering.approach")}
        </h2>
      </div>

      <dl class="space-y-12 max-w-4xl">
        {[
          { titleKey: 'cleanCode', descKey: 'cleanCodeDesc' },
          { titleKey: 'architecture', descKey: 'architectureDesc' },
          { titleKey: 'learning', descKey: 'learningDesc' },
          { titleKey: 'collaboration', descKey: 'collaborationDesc' },
        ].map((item) => (
          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 border-t hairline pt-8">
            <dt class="md:col-span-4 editorial-display text-xl text-paper">{t(`engineering.${item.titleKey}`)}</dt>
            <dd class="md:col-span-8 text-paper-muted leading-relaxed text-pretty">{t(`engineering.${item.descKey}`)}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section>
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-24 md:py-32">
      <p class="editorial-meta mb-8">07 / Contact</p>
      <h2 class="editorial-display text-3xl md:text-6xl text-paper mb-12 text-balance max-w-4xl">
        {t("engineering.contactTitle")}
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mb-16">
        <a href={`mailto:${SOCIAL_LINKS.email}`} class="border-t hairline pt-6 hover:text-paper transition-colors">
          <p class="editorial-meta text-paper-dim mb-3">Email</p>
          <p class="text-paper break-all">{SOCIAL_LINKS.email}</p>
        </a>
        <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="border-t hairline pt-6 hover:text-paper transition-colors">
          <p class="editorial-meta text-paper-dim mb-3">LinkedIn</p>
          <p class="text-paper">in/jfranciscorobles ↗</p>
        </a>
        <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="border-t hairline pt-6 hover:text-paper transition-colors">
          <p class="editorial-meta text-paper-dim mb-3">GitHub</p>
          <p class="text-paper">JFranciscoRobles ↗</p>
        </a>
      </div>

      <div class="flex flex-wrap gap-x-10 gap-y-4">
        <a
          href="/cv.pdf"
          download
          class="editorial-meta text-paper border-b border-paper hover:border-paper-muted hover:text-paper-muted pb-1 transition-colors"
        >
          {t("engineering.downloadCV")} ↓
        </a>
        <a
          href={`mailto:${SOCIAL_LINKS.email}`}
          class="editorial-meta text-paper-muted hover:text-paper transition-colors"
        >
          {t("engineering.scheduleCall")} →
        </a>
      </div>
    </div>
  </section>
</Global>

---
import Works from "../components/Works.astro";
import Global from "../layouts/Global.astro";
import { SOCIAL_LINKS } from "../consts";
import { t, changeLanguage } from "i18next";
import { HeadHrefLangs } from "astro-i18next/components";

changeLanguage("es");
---

<Global
  pageTitle="Sobre mí - J. Francisco Robles"
  description="Conoce mi trayectoria profesional como desarrollador full-stack. Experiencia en desarrollo de CRMs, e-commerce y soluciones web empresariales con JavaScript y tecnologías modernas."
  locale="es"
>
  <HeadHrefLangs slot="head" />

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 pt-24 pb-20 md:pt-32 md:pb-24">
      <p class="editorial-meta mb-12">Sobre — 01</p>
      <h1 class="editorial-display text-[2.25rem] sm:text-[3rem] md:text-[5rem] text-paper text-balance">
        {t("about.title")}
      </h1>
    </div>
  </section>

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
        <p class="md:col-span-2 editorial-meta">Intro</p>
        <div class="md:col-span-9 space-y-8 text-paper-muted text-lg leading-relaxed text-pretty">
          <p class="text-xl text-paper" set:html={t("about.intro1")} />
          <p set:html={t("about.intro2")} />
          <p set:html={t("about.intro3")} />
          <p set:html={t("about.intro4")} />
        </div>
      </div>
    </div>
  </section>

  <section class="border-b hairline bg-ink-raised">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <p class="md:col-span-2 editorial-meta">02</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("about.whatIDo")}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16">
        <div class="border-t hairline pt-8">
          <p class="editorial-meta text-paper-dim mb-4">01 / Frontend</p>
          <h3 class="editorial-display text-2xl text-paper mb-4">{t("about.frontend")}</h3>
          <p class="text-paper-muted leading-relaxed text-pretty">{t("about.frontendDesc")}</p>
        </div>
        <div class="border-t hairline pt-8">
          <p class="editorial-meta text-paper-dim mb-4">02 / Backend</p>
          <h3 class="editorial-display text-2xl text-paper mb-4">{t("about.backend")}</h3>
          <p class="text-paper-muted leading-relaxed text-pretty">{t("about.backendDesc")}</p>
        </div>
        <div class="border-t hairline pt-8">
          <p class="editorial-meta text-paper-dim mb-4">03 / Search</p>
          <h3 class="editorial-display text-2xl text-paper mb-4">{t("about.search")}</h3>
          <p class="text-paper-muted leading-relaxed text-pretty">{t("about.searchDesc")}</p>
        </div>
        <div class="border-t hairline pt-8">
          <p class="editorial-meta text-paper-dim mb-4">04 / Architecture</p>
          <h3 class="editorial-display text-2xl text-paper mb-4">{t("about.architecture")}</h3>
          <p class="text-paper-muted leading-relaxed text-pretty">{t("about.architectureDesc")}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <p class="md:col-span-2 editorial-meta">03</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("about.approach")}
        </h2>
      </div>

      <dl class="space-y-12 max-w-4xl">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 border-t hairline pt-8">
          <dt class="md:col-span-4 editorial-display text-xl text-paper">{t("about.cleanCode")}</dt>
          <dd class="md:col-span-8 text-paper-muted leading-relaxed text-pretty">{t("about.cleanCodeDesc")}</dd>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 border-t hairline pt-8">
          <dt class="md:col-span-4 editorial-display text-xl text-paper">{t("about.learning")}</dt>
          <dd class="md:col-span-8 text-paper-muted leading-relaxed text-pretty">{t("about.learningDesc")}</dd>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 border-t hairline pt-8">
          <dt class="md:col-span-4 editorial-display text-xl text-paper">{t("about.userFirst")}</dt>
          <dd class="md:col-span-8 text-paper-muted leading-relaxed text-pretty">{t("about.userFirstDesc")}</dd>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 border-t hairline pt-8">
          <dt class="md:col-span-4 editorial-display text-xl text-paper">{t("about.performance")}</dt>
          <dd class="md:col-span-8 text-paper-muted leading-relaxed text-pretty">{t("about.performanceDesc")}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="border-b hairline bg-ink-raised">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <Works />
    </div>
  </section>

  <section>
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-24 md:py-32">
      <p class="editorial-meta mb-8">Contacto</p>
      <h2 class="editorial-display text-3xl md:text-6xl text-paper mb-8 text-balance max-w-4xl">
        {t("about.letsTalk")}
      </h2>
      <p class="text-paper-muted text-lg mb-12 max-w-2xl leading-relaxed text-pretty">
        {t("about.letsTalkDesc")}
      </p>
      <a
        href={`mailto:${SOCIAL_LINKS.email}`}
        class="editorial-display text-2xl md:text-4xl text-paper hover:text-paper-muted transition-colors inline-block break-all"
      >
        {SOCIAL_LINKS.email}
        <span class="text-paper-dim"> →</span>
      </a>
    </div>
  </section>
</Global>

---
import Global from "../layouts/Global.astro";
import { SOCIAL_LINKS } from "../consts";
import { t, changeLanguage } from "i18next";
import { HeadHrefLangs } from "astro-i18next/components";

changeLanguage("es");
---

<Global
  pageTitle="Soluciones Web para Negocios - J. Francisco Robles"
  description="Creo sitios web y tiendas online que atraen clientes, generan ventas y ahorran tiempo. Soluciones digitales profesionales sin complicaciones técnicas."
  locale="es"
>
  <HeadHrefLangs slot="head" />

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 pt-24 pb-20 md:pt-32 md:pb-24">
      <p class="editorial-meta mb-12">Negocios — 01</p>
      <h1 class="editorial-display text-[2.25rem] sm:text-[3rem] md:text-[5rem] text-paper text-balance mb-12">
        {t("business.title")}
      </h1>
      <p class="text-paper-muted text-lg md:text-xl max-w-3xl leading-relaxed text-pretty mb-8">
        {t("business.subtitle")}
      </p>
      <p class="font-mono text-sm text-paper-dim mb-12 border-l hairline pl-4">
        {t("business.heroPriceTag")}
      </p>
      <div class="flex flex-wrap items-center gap-x-8 gap-y-4">
        <a
          href="https://wa.me/526645684580?text=Hola, me interesa saber más sobre los servicios web"
          target="_blank"
          rel="noopener noreferrer"
          class="editorial-meta text-ink bg-paper border-2 border-paper px-6 py-3 hover:bg-paper-muted hover:border-paper-muted transition-colors"
        >
          {t("business.sendWhatsApp")} ↗
        </a>
        <a
          href={`mailto:${SOCIAL_LINKS.email}?subject=Consulta sobre sitio web`}
          class="editorial-meta text-paper border-b border-paper hover:border-paper-muted hover:text-paper-muted pb-1 transition-colors"
        >
          {t("business.scheduleFree")} →
        </a>
      </div>
    </div>
  </section>

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-12">
        <p class="md:col-span-2 editorial-meta">02 / Diagnóstico</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("business.problems")}
        </h2>
      </div>
      <ul class="space-y-4 max-w-4xl mb-16">
        {['problem1','problem2','problem3','problem4','problem5'].map((key, i) => (
          <li class="flex gap-6 text-paper-muted leading-relaxed border-t hairline pt-6">
            <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-paper text-lg">{t(`business.${key}`)}</span>
          </li>
        ))}
      </ul>
      <div class="border-t hairline pt-8 max-w-3xl">
        <p class="editorial-meta mb-4">{t("business.goodNews")}</p>
        <p class="text-paper-muted text-lg leading-relaxed text-pretty">{t("business.goodNewsDesc")}</p>
      </div>
    </div>
  </section>

  <section class="border-b hairline bg-ink-raised">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <p class="md:col-span-2 editorial-meta">03 / Servicios</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("business.services")}
        </h2>
      </div>

      <div class="space-y-20">
        {[
          { n: '01', title: 'service1Title', price: 'service1Price', duration: 'service1Duration', intro: 'service1Intro', ideal: 'service1IdealFor', features: ['service1Feature1','service1Feature2','service1Feature3','service1Feature4','service1Feature5'], ideals: ['service1Ideal1','service1Ideal2','service1Ideal3','service1Ideal4'] },
          { n: '02', title: 'service2Title', price: 'service2Price', duration: 'service2Duration', intro: 'service2Intro', ideal: 'service2IdealFor', features: ['service2Feature1','service2Feature2','service2Feature3','service2Feature4','service2Feature5'], ideals: ['service2Ideal1','service2Ideal2','service2Ideal3'] },
          { n: '03', title: 'service3Title', price: 'service3Price', duration: 'service3Duration', intro: 'service3Intro', ideal: 'service3IdealFor', features: ['service3Feature1','service3Feature2','service3Feature3','service3Feature4'], ideals: ['service3Ideal1','service3Ideal2','service3Ideal3'] },
          { n: '04', title: 'service4Title', price: 'service4Price', duration: 'service4Duration', intro: null, ideal: null, features: ['service4Feature1','service4Feature2','service4Feature3','service4Feature4'], ideals: [] },
        ].map((s) => (
          <article class="border-t hairline pt-12">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-10">
              <p class="md:col-span-2 editorial-meta text-paper-dim">{s.n}</p>
              <div class="md:col-span-10">
                <h3 class="editorial-display text-2xl md:text-4xl text-paper mb-4">
                  {t(`business.${s.title}`)}
                </h3>
                <div class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-sm">
                  <span class="text-paper">{t(`business.${s.price}`)}</span>
                  <span class="text-paper-dim">— {t(`business.${s.duration}`)}</span>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
              <div class="md:col-span-2"></div>
              <div class="md:col-span-10 grid grid-cols-1 md:grid-cols-2 gap-12">
                <div>
                  {s.intro && <p class="editorial-meta text-paper-dim mb-4">{t(`business.${s.intro}`)}</p>}
                  <ul class="space-y-3">
                    {s.features.map((key) => (
                      <li class="flex gap-4 text-paper-muted leading-relaxed">
                        <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">—</span>
                        <span>{t(`business.${key}`)}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                {s.ideal && (
                  <div>
                    <p class="editorial-meta text-paper-dim mb-4">{t(`business.${s.ideal}`)}</p>
                    <ul class="space-y-3">
                      {s.ideals.map((key) => (
                        <li class="flex gap-4 text-paper-muted leading-relaxed">
                          <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">→</span>
                          <span>{t(`business.${key}`)}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-12">
        <p class="md:col-span-2 editorial-meta">04 / Caso</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("business.caseStudy")}
        </h2>
      </div>

      <article class="grid grid-cols-1 md:grid-cols-12 gap-8 border-t hairline pt-12 max-w-5xl">
        <div class="md:col-span-4">
          <p class="editorial-meta text-paper-dim mb-3">Cliente</p>
          <h3 class="editorial-display text-2xl md:text-3xl text-paper">{t("business.caseStudyTitle")}</h3>
        </div>
        <div class="md:col-span-7 md:col-start-6 space-y-6">
          <div>
            <p class="editorial-meta text-paper-dim mb-2">Antes</p>
            <p class="text-paper-muted text-lg leading-relaxed text-pretty">{t("business.caseStudyBefore")}</p>
          </div>
          <div>
            <p class="editorial-meta text-paper-dim mb-2">Después</p>
            <p class="text-paper-muted text-lg leading-relaxed text-pretty">{t("business.caseStudyAfter")}</p>
          </div>
          <div class="border-t hairline pt-6">
            <p class="editorial-meta text-paper-dim mb-2">Resultado</p>
            <p class="text-paper text-lg leading-relaxed text-pretty">{t("business.caseStudyResult")}</p>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="border-b hairline bg-ink-raised">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <p class="md:col-span-2 editorial-meta">05 / Proceso</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("business.process")}
        </h2>
      </div>

      <div class="space-y-16">
        <article class="grid grid-cols-1 md:grid-cols-12 gap-8 border-t hairline pt-12">
          <div class="md:col-span-4">
            <p class="editorial-meta text-paper-dim mb-3">Paso 01</p>
            <h3 class="editorial-display text-2xl md:text-3xl text-paper">{t("business.step1Title")}</h3>
          </div>
          <div class="md:col-span-7 md:col-start-6">
            <p class="text-paper-muted text-lg leading-relaxed mb-6 text-pretty">{t("business.step1Desc")}</p>
            <ul class="space-y-3 mb-6">
              {['step11','step12','step13','step14'].map((key) => (
                <li class="flex gap-4 text-paper-muted">
                  <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">—</span>
                  <span>{t(`business.${key}`)}</span>
                </li>
              ))}
            </ul>
            <p class="editorial-meta text-paper-dim">{t("business.step1Note")}</p>
          </div>
        </article>

        <article class="grid grid-cols-1 md:grid-cols-12 gap-8 border-t hairline pt-12">
          <div class="md:col-span-4">
            <p class="editorial-meta text-paper-dim mb-3">Paso 02</p>
            <h3 class="editorial-display text-2xl md:text-3xl text-paper">{t("business.step2Title")}</h3>
          </div>
          <div class="md:col-span-7 md:col-start-6">
            <p class="text-paper-muted text-lg leading-relaxed mb-6 text-pretty">{t("business.step2Desc")}</p>
            <ul class="space-y-3 mb-6">
              {['step21','step22','step23','step24'].map((key) => (
                <li class="flex gap-4 text-paper-muted">
                  <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">—</span>
                  <span>{t(`business.${key}`)}</span>
                </li>
              ))}
            </ul>
            <p class="editorial-meta text-paper-dim">{t("business.step2Note")}</p>
          </div>
        </article>

        <article class="grid grid-cols-1 md:grid-cols-12 gap-8 border-t hairline pt-12">
          <div class="md:col-span-4">
            <p class="editorial-meta text-paper-dim mb-3">Paso 03</p>
            <h3 class="editorial-display text-2xl md:text-3xl text-paper">{t("business.step3Title")}</h3>
          </div>
          <div class="md:col-span-7 md:col-start-6 space-y-8">
            <div>
              <p class="editorial-meta text-paper-dim mb-4">{t("business.step3IHandle")}</p>
              <ul class="space-y-3">
                {['step3IHandle1','step3IHandle2','step3IHandle3','step3IHandle4','step3IHandle5'].map((key) => (
                  <li class="flex gap-4 text-paper-muted">
                    <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">—</span>
                    <span>{t(`business.${key}`)}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <p class="editorial-meta text-paper-dim mb-4">{t("business.step3YouOnly")}</p>
              <ul class="space-y-3">
                {['step3YouOnly1','step3YouOnly2','step3YouOnly3'].map((key) => (
                  <li class="flex gap-4 text-paper-muted">
                    <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">→</span>
                    <span>{t(`business.${key}`)}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <p class="md:col-span-2 editorial-meta">06 / Beneficios</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("business.benefits")}
        </h2>
      </div>
      <ul class="space-y-4 max-w-4xl">
        {['benefits1','benefits2','benefits3','benefits4','benefits5'].map((key, i) => (
          <li class="flex gap-6 text-paper-muted leading-relaxed border-t hairline pt-6">
            <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-paper text-lg">{t(`business.${key}`)}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="border-b hairline bg-ink-raised">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <p class="md:col-span-2 editorial-meta">07 / FAQ</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("business.faq")}
        </h2>
      </div>

      <dl class="space-y-10 max-w-4xl">
        {['faq1','faq2','faq3','faq4','faq5','faq6'].map((key, i) => (
          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 border-t hairline pt-8">
            <dt class="md:col-span-5">
              <p class="editorial-meta text-paper-dim mb-3">{String(i + 1).padStart(2, '0')}</p>
              <p class="editorial-display text-xl text-paper">{t(`business.${key}Q`)}</p>
            </dt>
            <dd class="md:col-span-7 text-paper-muted leading-relaxed text-pretty">
              {t(`business.${key}A`)}
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="border-b hairline">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-24 md:py-32">
      <p class="editorial-meta mb-8">08 / {t("business.cta")}</p>
      <h2 class="editorial-display text-3xl md:text-6xl text-paper mb-8 text-balance max-w-4xl">
        {t("business.ctaTitle")}
      </h2>
      <p class="text-paper-muted text-lg mb-16 max-w-2xl leading-relaxed text-pretty">
        {t("business.ctaDesc")}
      </p>

      <a
        href={`mailto:${SOCIAL_LINKS.email}?subject=Consulta sobre sitio web`}
        class="editorial-display text-2xl md:text-4xl text-paper hover:text-paper-muted transition-colors inline-block break-all mb-16"
      >
        {SOCIAL_LINKS.email}
        <span class="text-paper-dim"> →</span>
      </a>

      <div class="flex flex-wrap items-center gap-x-8 gap-y-4">
        <a
          href="https://wa.me/526645684580?text=Hola, me interesa saber más sobre los servicios web"
          target="_blank"
          rel="noopener noreferrer"
          class="editorial-meta text-ink bg-paper border-2 border-paper px-6 py-3 hover:bg-paper-muted hover:border-paper-muted transition-colors"
        >
          {t("business.sendWhatsApp")} ↗
        </a>
        <a
          href={`mailto:${SOCIAL_LINKS.email}?subject=Consulta sobre sitio web`}
          class="editorial-meta text-paper border-b border-paper hover:border-paper-muted hover:text-paper-muted pb-1 transition-colors"
        >
          {t("business.scheduleCall")} →
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-12">
        <p class="md:col-span-2 editorial-meta">09 / Cierre</p>
        <h2 class="md:col-span-10 editorial-display text-3xl md:text-5xl text-paper text-balance">
          {t("business.finalNote")}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 max-w-5xl">
        <div class="md:col-span-2"></div>
        <div class="md:col-span-9 space-y-6">
          <p class="text-paper-muted text-lg leading-relaxed text-pretty">{t("business.finalNoteDesc")}</p>
          <p class="editorial-meta text-paper-dim pt-6 border-t hairline">{t("business.finalNoteMeans")}</p>
          <ul class="space-y-3">
            {['finalNotePoint1','finalNotePoint2','finalNotePoint3','finalNotePoint4'].map((key) => (
              <li class="flex gap-4 text-paper-muted">
                <span class="font-mono text-xs text-paper-dim pt-1.5 select-none" aria-hidden="true">—</span>
                <span>{t(`business.${key}`)}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</Global>
